# =============================================================================
# LLM Provider Configuration
# =============================================================================

# Option 1: Multi-Provider Configuration (Recommended for Production/Judging)
# Use this format to configure multiple API endpoints for round-robin load balancing
# with automatic failover. This prevents rate limiting issues during high traffic.
#
# Format: JSON array with provider objects
# Each provider needs: name, api_key, base_url (optional), model (optional), timeout (optional)
#
# Example with multiple providers:
# LLM_PROVIDERS='[{"name":"openai-primary","api_key":"sk-xxx","base_url":"https://api.openai.com/v1","model":"gpt-4o-mini","timeout":15},{"name":"openai-backup","api_key":"sk-yyy","base_url":"https://api.openai.com/v1","model":"gpt-4o-mini","timeout":15}]'
#
# LLM_PROVIDERS=

# Option 2: Single Provider Configuration (Legacy, for Development)
# This is the simple format for development with a single API key.
# If LLM_PROVIDERS is set, these values are ignored.
#
# OpenAI or OpenAI-compatible API Key
OPENAI_API_KEY=your_openai_api_key_here

# Base URL for the OpenAI-compatible service (defaults to https://api.openai.com/v1)
OPENAI_API_BASE=https://api.openai.com/v1

# Model Name (defaults to gpt-4o-mini)
MODEL_NAME=gpt-4o-mini

# =============================================================================
# Server Configuration
# =============================================================================

# Server Port
PORT=8000
